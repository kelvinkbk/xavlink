# Server Configuration
PORT=5000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/xavlink?schema=public"

# JWT Secret (generate a strong random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# CORS Origins (comma-separated)
CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:8081

# Frontend URL (for email verification links)
FRONTEND_URL=http://localhost:5173

# Email Configuration (optional - leave empty for development mode)
EMAIL_PROVIDER=gmail
# EMAIL_PROVIDER=smtp
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password

# SMTP Configuration (if using SMTP provider)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-smtp-user
# SMTP_PASSWORD=your-smtp-password

# Request Logging (set to "true" to enable in production)
LOG_REQUESTS=false

# Cloudinary Configuration (for file uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Web Push Notification Configuration (VAPID Keys)
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-public-key-from-web-push-generate
VAPID_PRIVATE_KEY=your-private-key-from-web-push-generate
VAPID_SUBJECT=mailto:your-email@example.com

# Firebase Configuration (optional - for additional push notifications)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}
